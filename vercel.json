{
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "functions": {
    "app/api/webhook/route.ts": { "maxDuration": 30 },
    "app/api/checkout/route.ts": { "maxDuration": 15 },
    "app/api/download/[token]/route.ts": { "maxDuration": 15 },
    "app/api/cron/abandon/route.ts": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/cron/abandon", "schedule": "0 12 * * *" }
  ]
}
