# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Resend (email) ---
RESEND_API_KEY=re_xxx
RESEND_FROM="Fini l'eau verte <noreply@tondomaine.fr>"

# --- App ---
NEXT_PUBLIC_URL=https://tondomaine.fr

# Secret HMAC pour signer les URLs de téléchargement (générer avec: openssl rand -hex 32)
DOWNLOAD_SIGNING_SECRET=changeme_32_bytes_hex

# Secret pour authentifier les appels Vercel Cron (générer avec: openssl rand -hex 32)
# Doit être identique à la variable Cron Secret configurée dans Vercel.
CRON_SECRET=changeme_32_bytes_hex

# --- Analytics (optionnel) ---
# Si défini, le script Plausible est injecté dans chaque page de vente.
# Ex: tondomaine.fr
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
